---
import { MdKeyboardArrowRight } from 'react-icons/md'

interface Props {
  title: string
  year: number
}

const { title, year } = Astro.props
---

<div class='inline-flex justify-center items-end gap-0.5 mb-3'>
  <a
    class='dark:text-purple-200 text-blue-500 font-medium hover:underline hover:underline-offset-[3px]'
    href='/projects'>Projects</a
  >

  <MdKeyboardArrowRight className='text-grey-200 text-xl pb-0.5' />

  <span class='text-xl font-semibold'>
    {title}
    <span
      class='px-1.5 py-0.5 rounded font-mono dark:bg-dark-400/50 bg-grey-200/20 backdrop-blur-md text-xs'
      >{year}</span
    >
  </span>
</div>
