---
import Title from './Title.astro'

import { IoDocument } from 'react-icons/io5'
---

<section class='py-40 relative flex flex-col gap-3' id='aboutme'>
  <Title>About me</Title>

  <article class='flex justify-center items-center'>
    <p class='text-sm font-medium'>
      <img
        src='/Jason.png'
        alt='emerzon javier kolki martinez'
        class='float-left w-32 h-32 rounded-full object-cover mr-3 border-4 border-dark-400'
      />

      <span class='dark:text-purple-200 text-purple-500'
        >Programming has become my favorite hobby</span
      > and, along with
      <span class='dark:text-blue-100 text-blue-400'
        >my love for challenges</span
      >, my goal is to develop web applications that meet client needs and
      create quality, robust applications using best practices.<br /><br />

      <span class='dark:text-purple-200 text-purple-500'
        >I constantly seek to learn and improve my knowledge every day</span
      >, and to achieve this I have developed my discipline, patience,
      adaptability, organization and for some projects my <span
        class='dark:text-blue-100 text-blue-400'>leadership and teamwork.</span
      >
    </p>
  </article>

  <a
    href='/documents/Emerzon Javier Kolki Martinez - CV.pdf'
    class='self-center py-1.5 px-4 text-white rounded-md bg-blue-500 hover:bg-blue-100 dark:bg-purple-500 dark:hover:bg-purple-200 text-center flex gap-1 transition-colors duration-300'
  >
    <IoDocument className='text-xl' />
    <span>Download CV</span>
  </a>
</section>
